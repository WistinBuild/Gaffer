# Copy to .env.local — fill these in after deploying the contracts to Base Sepolia (chainId 84532)
# Run `npm run deploy:testnet --workspace=packages/contracts` and paste the printed addresses below.

# ─── Solana devnet (on-chain layer migration target) ─────────────────────────
# The connect modal defaults to Solana devnet. Override the RPC to avoid the
# public devnet endpoint's rate limits (Helius/Triton devnet URL).
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
# Anchor program IDs (see packages/programs). Oracle is ported + deployed first;
# the rest follow as they are migrated off the EVM contracts below.
NEXT_PUBLIC_ORACLE_PROGRAM_ID=3byJrFHoZ4v9tTo9XAKn1KrE82LZSAxwqMDijVXMf5Yb
NEXT_PUBLIC_GAFFER_NFT_PROGRAM_ID=Fhk54QhcVjY7phpxzF7HCPa6STsYD1FN8Jfwk2irdkGf
NEXT_PUBLIC_PLAYER_MINT_PROGRAM_ID=D9xiskVonYcZs3zMnjeKS9HY27s2fcBxTD3Jw5op2XoY
NEXT_PUBLIC_SQUAD_WARS_PROGRAM_ID=25MeET8DMNgM8VCJTXxDQVPAaJsp5HezyhypofbYdaqh
# USDC SPL mint used for stakes/mints (Circle devnet USDC by default).
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Server-only Solana RPC for metadata/bot routes (optional; defaults to the
# public devnet endpoint). May embed a provider key, so NOT NEXT_PUBLIC.
SOLANA_RPC_URL=https://api.devnet.solana.com
# Bot/treasury keypair for /api/bot/* (JSON byte array from a Solana CLI keypair
# file, or a base58 secret). Must be the Oracle owner + SquadWars resolver — i.e.
# the deployer key. NEVER prefix with NEXT_PUBLIC.
SOLANA_TREASURY_SECRET=

# ─── EVM network (legacy — contracts pending Anchor rewrite) ──────────────────
NEXT_PUBLIC_CHAIN_ID=84532
# Server-only RPC used by the metadata routes (ZAN/Alchemy/QuickNode). It embeds
# an API key, so it is NOT prefixed NEXT_PUBLIC (would leak into the client bundle).
# Falls back to the public, rate-limited endpoint if unset.
RPC_URL=https://sepolia.base.org

# ─── Deployed contract addresses ──────────────────────────────────────────────
NEXT_PUBLIC_ORACLE_ADDRESS=
NEXT_PUBLIC_NFT_ADDRESS=
NEXT_PUBLIC_SQUAD_WARS_ADDRESS=
NEXT_PUBLIC_PLAYER_MINT_ADDRESS=
# USDC payment token (Circle USDC on Base Sepolia). All stakes/mints are paid in USDC.
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ─── Frontend / metadata ──────────────────────────────────────────────────────
# Public site origin — used for wallet metadata AND the NFT tokenURI image links.
# Must match the domain you set via scripts/set-base-uri.mjs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# WalletConnect Cloud project id (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ─── Server-only secrets (NEVER prefix with NEXT_PUBLIC) ──────────────────────
# Treasury/bot hot wallet that acts as the auto-opponent + oracle. Use a
# dedicated low-balance key, NOT the deployer/owner key.
TREASURY_PRIVATE_KEY=
# Shared secret required to call /api/bot/* . Generate: openssl rand -hex 32
# If unset, the bot endpoints are disabled (return 503).
BOT_TRIGGER_SECRET=
